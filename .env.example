APP_ENV=local
APP_URL=http://localhost:8081
APP_SECRET=change-me-in-production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=farmq
DB_USER=farmq
DB_PASS=farmq_secret

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

DEV_UNLOCK_PAID=1

DEFAULT_LOCALE=ar
SUPPORTED_LOCALES=en,ar

PAYMENT_GATEWAY=paymob
# Leave PAYMENT_GATEWAY_API_KEY empty to run the built-in sandbox checkout.
PAYMENT_GATEWAY_API_KEY=
# Paymob live integration (required only when going live):
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
# Subscription pricing
SUBSCRIPTION_PRICE_EGP=450
SUBSCRIPTION_DAYS=180

# Geospatial (Wave 3) — Earth Search STAC, no API key required
GEOSPATIAL_STAC_URL=https://earth-search.aws.element84.com/v1
GEOSPATIAL_MAX_CLOUD_PCT=35

# Optional: notify admin when demo form is submitted
DEMO_NOTIFY_EMAIL=

# Optional (Wave 5): email address to receive agronomic alert digests
ALERT_NOTIFY_EMAIL=
